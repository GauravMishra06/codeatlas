# ─── GitHub OAuth App ────────────────────────────────────────
# Create at: https://github.com/settings/developers
# Homepage URL: http://localhost:5173
# Callback URL: http://localhost:3000/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ─── GitHub Webhook ──────────────────────────────────────────
# Set when creating a webhook on your repo
# Settings → Webhooks → Add webhook
GITHUB_WEBHOOK_SECRET=

# ─── MongoDB Atlas ───────────────────────────────────────────
# Create free cluster at: https://www.mongodb.com/atlas
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/codeatlas
MONGODB_URI=

# ─── Cognee ──────────────────────────────────────────────────
# Cognee local server URL
COGNEE_URL=http://localhost:8000
# COGNEE_API_KEY=

# ─── Gemini API (Google AI Studio) ──────────────────────────
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# ─── Groq API key (free at console.groq.com — used as fallback when Gemini rate limits)
GROQ_API_KEY=

# ─── JWT Secret ──────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

# ─── App Config ──────────────────────────────────────────────
CLIENT_URL=http://localhost:5173
PORT=3000
