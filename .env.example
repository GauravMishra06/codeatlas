# ─── Server Environment Variables ────────────────────────────
# Copy this file to server/.env and fill in the values.
# NEVER commit .env files with real secrets!

# GitHub OAuth App credentials
# Create at: https://github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# GitHub Webhook secret (set when creating the webhook)
GITHUB_WEBHOOK_SECRET=

# MongoDB Atlas connection string
# Example: mongodb+srv://user:pass@cluster.mongodb.net/codeatlas
MONGODB_URI=

# Cognee Server URL (running locally)
COGNEE_URL=http://localhost:8000

# Cognee API key (if needed in production, though local is auth-free)
# COGNEE_API_KEY=

# Gemini API key (for PR analysis and Chat)
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# JWT signing secret (generate a random 64-char string)
JWT_SECRET=

# Frontend URL (for CORS and OAuth redirects)
CLIENT_URL=http://localhost:5173

# Server port
PORT=3000

# ─── Client Environment Variables ────────────────────────────
# Copy this to client/.env
# VITE_API_URL=http://localhost:3000
